// Handicrafts E-Commerce — Prisma Schema
// Migrated from MongoDB Atlas (Mongoose) → MySQL (cPanel)
// 10 MongoDB collections → 14 MySQL tables

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// 1. PRODUCT
// MongoDB: images[] and tags[] were arrays inside one document.
// MySQL: They become separate tables linked by product_id.
// ─────────────────────────────────────────────────────────────────

model Product {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(255)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  salePrice   Decimal? @map("sale_price") @db.Decimal(10, 2)
  category    String?  @db.VarChar(50)
  stock       Int      @default(0)
  artisan     String?  @db.VarChar(255)
  featured    Boolean  @default(false)
  rating      Decimal  @default(0) @db.Decimal(3, 2)
  reviews     Int      @default(0)
  weight      Decimal  @default(1) @db.Decimal(10, 2)
  length      Decimal  @default(15) @db.Decimal(10, 2)
  breadth     Decimal  @default(15) @db.Decimal(10, 2)
  height      Decimal  @default(10) @db.Decimal(10, 2)
  quantity    String?  @db.VarChar(100)
  size        String?  @db.VarChar(100)
  material    String?  @db.VarChar(100)
  color       String?  @db.VarChar(100)
  type        String?  @db.VarChar(50)
  video       String?  @db.VarChar(500)
  ctaType     String?  @map("cta_type") @db.VarChar(50)
  ctaLabel    String?  @map("cta_label") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  images                   ProductImage[]
  tags                     ProductTag[]
  wholesaleCatalogProducts WholesaleCatalogProduct[]

  // Indexes (reproducing MongoDB indexes)
  @@index([category])
  @@index([featured])
  // Note: FULLTEXT index for title+description added below via raw SQL if needed
  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  url       String  @db.VarChar(500)
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductTag {
  id        Int    @id @default(autoincrement())
  productId Int    @map("product_id")
  tag       String @db.VarChar(100)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_tags")
}

// ─────────────────────────────────────────────────────────────────
// 2. CUSTOMER
// addresses[] → separate table
// cart and wishlist stay as JSON columns (MySQL supports this)
// ─────────────────────────────────────────────────────────────────

model Customer {
  id          Int            @id @default(autoincrement())
  firebaseUid String         @unique @map("firebase_uid") @db.VarChar(128)
  name        String         @db.VarChar(255)
  email       String?        @db.VarChar(255)
  phone       String?        @db.VarChar(20)
  role        CustomerRole   @default(customer)
  orders      Int            @default(0)
  totalSpent  Decimal        @default(0) @map("total_spent") @db.Decimal(12, 2)
  status      CustomerStatus @default(active)
  cart        Json           @default("[]")
  wishlist    Json           @default("[]")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  addresses CustomerAddress[]

  @@map("customers")
}

enum CustomerRole {
  customer
  admin
}

enum CustomerStatus {
  active
  inactive
  banned
}

model CustomerAddress {
  id         Int        @id @default(autoincrement())
  customerId Int        @map("customer_id")
  tag        AddressTag @default(home)
  name       String     @db.VarChar(255)
  phone      String     @db.VarChar(20)
  street     String     @db.VarChar(500)
  city       String     @db.VarChar(100)
  state      String?    @db.VarChar(100)
  pincode    String     @db.VarChar(10)
  isDefault  Boolean    @default(false) @map("is_default")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_addresses")
}

enum AddressTag {
  home
  work
  other
}

// ─────────────────────────────────────────────────────────────────
// 3. ORDER
// The nested payment, logistics, shippingAddress objects are
// flattened into columns on the same table.
// items[] → separate order_items table
// ─────────────────────────────────────────────────────────────────

model Order {
  id              Int             @id @default(autoincrement())
  // IMPORTANT: stores a Firebase UID string — NOT a database foreign key
  customerId      String          @map("customer_id") @db.VarChar(128)
  totalAmount     Decimal         @map("total_amount") @db.Decimal(12, 2)
  shippingFee     Decimal         @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  wholesaleToken  String?         @map("wholesale_token") @db.VarChar(50)

  // Payment fields (flattened from payment: { status, orderId, paymentId, signature })
  paymentStatus     PaymentStatus @default(Pending) @map("payment_status")
  paymentOrderId    String?       @map("payment_order_id") @db.VarChar(100)
  paymentPaymentId  String?       @map("payment_payment_id") @db.VarChar(100)
  paymentSignature  String?       @map("payment_signature") @db.VarChar(255)

  // Logistics fields (flattened from logistics: { status, awbCode, shipmentId, timestamps })
  logisticsStatus     LogisticsStatus @default(Placed) @map("logistics_status")
  logisticsAwbCode    String?         @map("logistics_awb_code") @db.VarChar(50)
  logisticsShipmentId String?         @map("logistics_shipment_id") @db.VarChar(50)
  placedAt            DateTime        @default(now()) @map("placed_at")
  packedAt            DateTime?       @map("packed_at")
  dispatchedAt        DateTime?       @map("dispatched_at")
  inTransitAt         DateTime?       @map("in_transit_at")
  deliveredAt         DateTime?       @map("delivered_at")

  // Coupon fields (flattened from coupon: { code, discount })
  couponCode     String?  @map("coupon_code") @db.VarChar(50)
  couponDiscount Decimal? @map("coupon_discount") @db.Decimal(10, 2)

  // Shipping address (flattened from shippingAddress: { name, phone, address, city, pincode })
  shippingName    String @map("shipping_name") @db.VarChar(100)
  shippingPhone   String @map("shipping_phone") @db.VarChar(15)
  shippingAddress String @map("shipping_address") @db.VarChar(500)
  shippingCity    String @map("shipping_city") @db.VarChar(100)
  shippingPincode String @map("shipping_pincode") @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  items OrderItem[]

  // Indexes (reproducing MongoDB indexes)
  @@index([customerId])
  @@index([paymentOrderId])
  @@index([logisticsStatus])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

enum PaymentStatus {
  Pending
  Paid
  Failed
}

enum LogisticsStatus {
  Placed
  Packed
  Dispatched
  In_Transit
  Delivered
  Cancelled
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  orderId       Int     @map("order_id")
  // itemProductId = the product's custom string id (e.g. "prod-001") — NOT a foreign key
  itemProductId String  @map("item_product_id") @db.VarChar(100)
  slug          String? @db.VarChar(255)
  title         String  @db.VarChar(255)
  qty           Int
  price         Decimal @db.Decimal(10, 2)
  image         String? @db.VarChar(500)
  customization Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────
// 4. COUPON
// ─────────────────────────────────────────────────────────────────

model Coupon {
  id          Int        @id @default(autoincrement())
  customId    String     @map("custom_id") @db.VarChar(50)
  code        String     @unique @db.VarChar(50)
  description String     @db.Text // required: true in original model
  discount    Decimal    @default(0) @db.Decimal(10, 2)
  type        CouponType @default(percentage)
  minOrder    Decimal    @default(0) @map("min_order") @db.Decimal(10, 2)
  maxUses     Int?       @map("max_uses")
  usedCount   Int        @default(0) @map("used_count")
  validUntil  DateTime?  @map("valid_until")
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("coupons")
}

enum CouponType {
  percentage
  flat
}

// ─────────────────────────────────────────────────────────────────
// 5. OFFER
// ─────────────────────────────────────────────────────────────────

model Offer {
  id          Int       @id @default(autoincrement())
  customId    String    @map("custom_id") @db.VarChar(50)
  title       String    @db.VarChar(255)
  description String    @db.Text
  discount    Decimal   @default(0) @db.Decimal(10, 2)
  type        OfferType @default(percentage)
  category    String?   @db.VarChar(100)
  icon        String?   @db.VarChar(100)
  image       String?   @db.VarChar(500)
  bgColor     String    @default("#7A1F1F") @map("bg_color") @db.VarChar(20)
  textColor   String    @default("#FFFFFF") @map("text_color") @db.VarChar(20)
  validUntil  DateTime? @map("valid_until")
  active      Boolean   @default(true)
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("offers")
}

enum OfferType {
  percentage
  flat
  shipping
}

// ─────────────────────────────────────────────────────────────────
// 6. HERO SLIDE
// ─────────────────────────────────────────────────────────────────

model HeroSlide {
  id          Int      @id @default(autoincrement())
  customId    String   @map("custom_id") @db.VarChar(50)
  title       String   @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  description String?  @db.Text
  badge       String?  @db.VarChar(100)
  video       String?  @db.VarChar(500)
  poster      String?  @db.VarChar(500)
  productSlug String?  @map("product_slug") @db.VarChar(255)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hero_slides")
}

// ─────────────────────────────────────────────────────────────────
// 7. SITE CONFIG  (singleton — always exactly 1 row in this table)
// ─────────────────────────────────────────────────────────────────

model SiteConfig {
  id                    Int      @id @default(autoincrement())
  promoBannerText       String   @default("Special Offer: Get FLAT 40% OFF!") @map("promo_banner_text") @db.VarChar(500)
  promoBannerActive     Boolean  @default(true) @map("promo_banner_active")
  email                 String   @default("info@balajihandicrafts.in") @db.VarChar(255)
  phone                 String   @default("9198492515") @db.VarChar(20)
  whatsapp              String   @default("984925153") @db.VarChar(20)
  address               String   @default("Charminar, Hyderabad") @db.VarChar(500)
  shippingFee           Decimal  @default(199) @map("shipping_fee") @db.Decimal(10, 2)
  freeShippingThreshold Decimal  @default(1000) @map("free_shipping_threshold") @db.Decimal(10, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("site_config")
}

// ─────────────────────────────────────────────────────────────────
// 8. SITE CONTENT  (singleton — JSON fields store nested CMS data)
// ─────────────────────────────────────────────────────────────────

model SiteContent {
  id        Int      @id @default(autoincrement())
  about     Json?
  contact   Json?
  footer    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("site_content")
}

// ─────────────────────────────────────────────────────────────────
// 9. TESTIMONIAL
// ─────────────────────────────────────────────────────────────────

model Testimonial {
  id        Int      @id @default(autoincrement())
  customId  String   @map("custom_id") @db.VarChar(50)
  name      String   @db.VarChar(255)
  city      String?  @db.VarChar(100)
  avatar    String?  @db.VarChar(500)
  rating    Int      @default(5)
  text      String   @db.Text
  product   String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("testimonials")
}

// ─────────────────────────────────────────────────────────────────
// 10. WHOLESALE CATALOG
// products[] → separate join table with FK to products table
// ─────────────────────────────────────────────────────────────────

model WholesaleCatalog {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  accessToken    String    @unique @map("access_token") @db.VarChar(50)
  expiryDate     DateTime? @map("expiry_date")
  isActive       Boolean   @default(true) @map("is_active")
  lockedToDevice String?   @map("locked_to_device") @db.VarChar(100)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  products WholesaleCatalogProduct[]

  @@map("wholesale_catalogs")
}

model WholesaleCatalogProduct {
  id             Int     @id @default(autoincrement())
  catalogId      Int     @map("catalog_id")
  productId      Int     @map("product_id")
  wholesalePrice Decimal @map("wholesale_price") @db.Decimal(10, 2)

  catalog WholesaleCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("wholesale_catalog_products")
}
